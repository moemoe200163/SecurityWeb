# =============================================================================
# SecurityWeb — Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose.
# This file is for docker-compose.yml variable substitution only.
# Backend-specific secrets go in backend/.env.

# Database credentials (must match backend/.env DATABASE_URL)
POSTGRES_USER=securityweb
POSTGRES_PASSWORD=changeme_use_strong_password
POSTGRES_DB=securityweb

# Backend service (referenced by docker-compose.yml environment block)
DATABASE_URL="postgresql://securityweb:changeme_use_strong_password@db:5432/securityweb"
MINIMAX_API_KEY=""
MINIMAX_API_ENDPOINT="https://api.minimax.chat/v1"
MINIMAX_MODEL="MiniMax-M2.7"

# CORS — comma-separated origins (e.g. "https://app.example.com,https://admin.example.com")
ALLOWED_ORIGINS="http://localhost:3000"
