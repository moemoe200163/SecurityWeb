generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String    @id @default(uuid())
  module    String    // "soc" | "threat" | "pentest"
  input     Json      // Original input data
  status    String    @default("in_progress") // "in_progress" | "completed"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  steps     Step[]
  messages  Message[]
  evidence  Evidence[]

  @@index([module])
  @@index([status])
  @@index([createdAt])
}

model Step {
  id         String    @id @default(uuid())
  sessionId  String
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order      Int
  title      String
  status     String    @default("pending") // "pending" | "running" | "success" | "error"
  content    String?
  codeBlock  String?
  toolCalls  Json?
  timestamp  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([sessionId])
  @@index([status])
}

model Message {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())

  @@index([sessionId])
}

// IP 信譽資料庫
model IpReputation {
  id              String   @id @default(uuid())
  ipAddress       String   @unique  // IP 地址
  status          String   @default("unknown")  // "malicious" | "suspicious" | "normal" | "unknown"
  threatLevel     String?  // "high" | "medium" | "low" | "none"
  confidenceScore Int?     // AbuseIPDB confidence score (0-100)
  countryCode     String?
  countryName     String?
  isp             String?
  domain          String?
  usageType       String?
  totalReports    Int?
  lastReportedAt  DateTime?
  isWhitelisted  Boolean  @default(false)
  sources         Json?    // 來源資料庫陣列
  firstSeen       DateTime?
  lastSeen        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ipAddress])
  @@index([status])
  @@index([threatLevel])
  @@index([createdAt])
}

// API 使用量追蹤
model ApiUsage {
  id          String   @id @default(uuid())
  apiName     String   // "AbuseIPDB" | "OTX" | "VirusTotal"
  date        DateTime @default(now()) @map("date")
  requestCount Int     @default(0)
  dailyLimit  Int      @default(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([apiName, date])
  @@index([apiName])
  @@index([date])
}

// BGP 即時更新記錄（最近 24 小時）
model BgpUpdate {
  id        BigInt    @id @default(autoincrement())
  prefix    String    // IP prefix (e.g., "192.168.1.0/24")
  asPath    String?   @db.Text           // AS 路徑 (e.g., "12345 67890 54321")
  peerAsn   BigInt?                       // 對等 AS 號碼
  originAsn BigInt?                       // 起源 AS 號碼
  timestamp DateTime  @default(now())      // BGP update 時間
  type      String    @default("A")      // A=Announce, W=Withdraw
  source    String?                       // RIPE RIS collector 名稱
  country   String?                       // AS 國家

  @@index([prefix])
  @@index([originAsn])
  @@index([timestamp])
  @@index([timestamp, prefix])
}

// AS 資訊資料表（從 bgp.tools 同步）
model BgpAsnInfo {
  asn       BigInt    @id
  name      String?
  country   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([asn])
}

// 系統設定
model SystemSetting {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  value     String
  desc      String?
  updatedAt DateTime @updatedAt

  @@index([key])
}

// URLhaus cache
model UrlHausResult {
  id           String   @id @default(uuid())
  domain       String   @unique
  malicious    Boolean  @default(false)
  status       String   // "online" | "offline" | "unknown" | "clean"
  threatType   String?  // "malware_url" | "phishing_url" | etc.
  blacklists   Json?
  urlCount     Int      @default(0)
  lastSeen     DateTime?
  firstSeen   DateTime?
  cannedResponse Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([malicious])
  @@index([createdAt])
}

// OTX cache
model OtxResult {
  id            String   @id @default(uuid())
  indicatorType String   @unique // "${type}_${indicator}"
  indicator     String
  type          String
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([indicatorType])
  @@index([indicator])
  @@index([type])
}

// ============== Week 1: New Models for Tool Platform ==============

model User {
  id        String  @id @default(uuid())
  // Nullable: revocation clears the row. First 11 chars ("sk-" + 8 hex) used for DB lookup.
  keyPrefix String? @unique @map("key_prefix")
  // Nullable: revocation clears the row. SHA-256 of full key (64-char hex).
  hashedKey    String?   @unique @map("hashed_key")
  // May predate `createdAt` if the user was created by admin without a key; backfilled from `createdAt` for existing rows.
  keyCreatedAt DateTime? @map("key_created_at")
  // Set when an admin (or self-service) revokes the key. NULL means key is active.
  keyRevokedAt DateTime? @map("key_revoked_at")
  // Optional expiry; checked at auth time, not enforced by the database.
  keyExpiresAt DateTime? @map("key_expires_at")
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  toolExecutions ToolExecution[]
  auditLogs      AuditLog[]
  evidence       Evidence[]

  @@map("users")
}

model ToolTemplate {
  id               String   @id @default(uuid())
  name             String
  tool             String   // nmap, sqlmap, nikto, hydra, holehe
  description      String?
  commandTemplate  String   @map("command_template")
  allowedParams    Json     @map("allowed_params") // Record<string, string[]>
  riskLevel        String   @default("low") // "low" | "medium" | "high"
  isApproved       Boolean  @default(false) @map("is_approved")
  isEnabled        Boolean  @default(true) @map("is_enabled")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  toolExecutions ToolExecution[]

  @@map("tool_templates")
}

model ToolExecution {
  id         String    @id @default(uuid())
  templateId String    @map("template_id")
  // Template is optional because the API can record failed attempts whose
  // template_id does not match a current row in tool_templates. The DB does
  // not enforce a FK (see migration 20260520000000_add_all_tables).
  template   ToolTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  sessionId  String?   @map("session_id")
  params     Json
  status     String    @default("pending") // "pending" | "running" | "success" | "error" | "timeout"
  output     String?
  error      String?
  exitCode   Int?      @map("exit_code")
  durationMs Int?      @map("duration_ms")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("tool_executions")
  @@index([createdAt])
  @@index([status])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  action       String   // "create" | "update" | "delete" | "execute" | "import" | etc.
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  details      Json?
  createdAt    DateTime @default(now())

  @@map("audit_logs")
  @@index([createdAt])
  @@index([action])
  @@index([resourceType])
}

model Alert {
  id               String   @id @default(uuid())
  source           String   // "import" | "api" | "demo" | "integration"
  title            String
  severity         String   // "critical" | "high" | "medium" | "low" | "info"
  rawContent       String   @db.Text @map("raw_content")
  normalizedFields Json?    @map("normalized_fields")
  aiVerdict        String?  @map("ai_verdict")
  humanVerdict     String?  @map("human_verdict")
  status           String   @default("new") // "new" | "investigating" | "resolved" | "ignored" | "false_positive"
  sessionId        String?  @map("session_id")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  knowledgeFeedback KnowledgeFeedback[]

  @@map("alerts")
}

model KnowledgeFeedback {
  id             String   @id @default(uuid())
  alertId        String   @map("alert_id")
  alert          Alert    @relation(fields: [alertId], references: [id])
  sessionId      String?  @map("session_id")
  aiVerdict      String   @map("ai_verdict")
  correctVerdict String   @map("correct_verdict")
  errorReason    String?  @map("error_reason")
  lesson         String?  // 知識補充
  createdAt      DateTime @default(now())

  @@map("knowledge_feedback")
}

model Evidence {
  id              String    @id @default(uuid())
  sessionId       String    @map("session_id")
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  alertId         String?   @map("alert_id")
  toolExecutionId String?   @map("tool_execution_id")
  type            String    // "tool" | "intelligence" | "manual" | "ai"
  title           String
  content         String    @db.Text  // Human-readable summary
  data            Json?                // Structured payload (tool output, intel result, etc.)
  createdById     String?   @map("created_by_id")
  createdBy       User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([sessionId])
  @@index([alertId])
  @@index([type])
  @@map("evidence")
}
