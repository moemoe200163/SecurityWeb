FROM python:3.11-slim

WORKDIR /app

# Install system deps for psycopg2
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY requirements-bgp.txt .
RUN pip install --no-cache-dir -r requirements-bgp.txt

# Copy scripts
COPY scripts/bgp-wrapper.py .
COPY scripts/bgp-consumer.py .

ENV PYTHONUNBUFFERED=1

# Run wrapper (controls allowed hours)
CMD ["python", "bgp-wrapper.py"]